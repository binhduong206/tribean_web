@model IEnumerable<Tribean.Models.Category>
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    var totalProducts = ViewData["TotalProducts"] as int? ?? 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentPage = (int)(ViewData["Page"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/categories.css" />
}

@* ── Thông báo ── *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Product Categories</h1>
        <p>Manage and organise your product catalog.</p>
    </div>
    <div class="page-header-actions">
        <a href="/Admin/Category/Create" class="btn btn-primary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Category
        </a>
    </div>
</div>

@* ── Thanh Tìm kiếm (Đồng bộ với Product/User) ── *@
<form method="get" action="/Admin/Category" id="filterForm">
    <div class="filter-bar" style="margin-bottom: 20px; display: flex; gap: 10px;">
        <div class="filter-search">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
            <input type="text" name="search" value="@currentSearch" placeholder="Search categories..." autocomplete="off"/>
        </div>
        @if (!string.IsNullOrEmpty(currentSearch))
        {
            <a href="/Admin/Category" class="btn btn-secondary btn-sm" style="display: flex; align-items: center;">✕ Clear</a>
        }
    </div>
</form>

<div class="card cat-table-section">
    <div class="card-header">
        <span class="card-title">All Categories</span>
        <span style="font-size:13px;color:var(--text-muted);">@Model.Count() items on this page</span>
    </div>
    
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th>Category Name</th>
                    <th>Products Count</th>
                    <th>Inventory Share</th>
                    <th style="width:100px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = (currentPage - 1) * 10 + 1; }
                @foreach (var cat in Model)
                {
                    var productCount = cat.Products?.Count ?? 0;
                    var pct = Math.Round((double)productCount / totalProducts * 100, 1);

                    <tr>
                        <td style="color:var(--text-muted);font-size:13px;">@(idx++)</td>
                        <td><span style="font-weight:500;">@cat.CategoryName</span></td>
                        <td>@productCount products</td>
                        <td>
                            <div class="cat-progress-wrap">
                                <div class="cat-progress">
                                    <div class="cat-progress-bar" style="width:@pct%"></div>
                                </div>
                                <span class="cat-progress-val">@pct%</span>
                            </div>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a href="/Admin/Category/Edit/@cat.Id" class="action-btn edit" title="Edit">
                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="18">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </a>
                                <form method="post" action="/Admin/Category/Delete/@cat.Id" style="display:inline;" onsubmit="return confirm('Xóa danh mục này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="action-btn delete" title="Delete">
                                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="18">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ── Thanh Phân Trang (Đồng bộ với Product) ── *@
    <div class="card-header" style="border-top:1px solid var(--card-border); border-bottom:none;">
        <span style="font-size:13px;color:var(--text-muted);">
            Page @currentPage of @totalPages
        </span>
        <div class="pagination">
            <a class="page-btn @(currentPage <= 1 ? "disabled" : "")" 
               href="?page=@(currentPage - 1)&search=@currentSearch">‹</a>
            
            @for (int i = 1; i <= totalPages; i++)
            {
                <a class="page-btn @(i == currentPage ? "active" : "")" 
                   href="?page=@i&search=@currentSearch">@i</a>
            }
            
            <a class="page-btn @(currentPage >= totalPages ? "disabled" : "")" 
               href="?page=@(currentPage + 1)&search=@currentSearch">›</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/js/alert.js"></script>
}