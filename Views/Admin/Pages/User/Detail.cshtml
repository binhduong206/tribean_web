@* Views/Admin/Pages/User/Detail.cshtml *@
@model Tribean.Models.User
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "User Detail";
    ViewData["PageTitle"] = "User Detail";
    ViewData["Breadcrumb"] = "Catalog / Users / Detail";
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/products.css" />
    <link rel="stylesheet" href="~/Admin/css/users.css" />
    @* Kế thừa luôn file CSS của Product để lấy form chuẩn của detail-grid *@
}

<div class="page-header">
    <div class="page-header-info">
        <h1>User Detail</h1>
        <p>Viewing details for <strong>@Model.UserName</strong></p>
    </div>
    <div class="page-header-actions header-actions-group">
        <a href="/Admin/User" class="btn btn-secondary btn-sm btn-icon-wrapper">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Users
        </a>
        <a href="/Admin/User/Edit/@Model.Id" class="btn btn-primary btn-sm btn-icon-wrapper">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit Profile
        </a>
    </div>
</div>

<div class="detail-grid">
    @* ── Cột Trái: Hình Ảnh (Avatar) ── *@
    <div class="detail-image-box" style="display: flex; flex-direction: column; justify-content: center;">
        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
        {
            <img src="@Model.AvatarUrl" alt="@Model.UserName" class="user-detail-avatar" />
        }
        else
        {
            <div class="user-empty-avatar">
                <span>👤</span>
            </div>
            <p class="empty-image-text" style="text-align: center; margin-top: 16px;">No avatar uploaded</p>
        }
    </div>

    @* ── Cột Phải: Thông tin chi tiết ── *@
    <div class="detail-info-box">
        @{
            var fullName = string.IsNullOrWhiteSpace(Model.FirstName) && string.IsNullOrWhiteSpace(Model.LastName)
                            ? Model.UserName : $"{Model.FirstName} {Model.LastName}".Trim();
        }
        <h2 class="detail-title">@fullName</h2>
        
        <div class="detail-meta">
            <span class="badge @(Model.Role?.RoleName == "Admin" ? "badge-purple" : "badge-green") detail-badge">
                @(Model.Role?.RoleName ?? "Client")
            </span>
            <span class="badge badge-blue detail-badge" style="background: var(--content-bg); color: var(--text-secondary);">
                @Model.UserName
            </span>
        </div>

        @* ── Tận dụng khối Giá (detail-price-box) để làm khối Thống kê cực đẹp ── *@
        <div class="detail-price-box" style="display: flex; justify-content: space-around; align-items: center; text-align: center;">
            <div>
                <span class="price-label">Total Orders</span>
                <span class="price-final" style="color: var(--sb-accent);">@Model.Orders.Count</span>
            </div>
            
            <div class="user-stat-divider">
                <span class="price-label">Product Reviews</span>
                <span class="price-final" style="color: var(--blue);">@Model.Reviews.Count</span>
            </div>
        </div>

        <h4 class="detail-section-title">Account Information</h4>
        
        <div class="info-row">
            <div class="info-label">Email</div>
            <div>@Model.Email</div>
        </div>
        <div class="info-row">
            <div class="info-label">Phone Number</div>
            <div>@(string.IsNullOrEmpty(Model.PhoneNumber) ? "—" : Model.PhoneNumber)</div>
        </div>
        <div class="info-row">
            <div class="info-label">Birthday</div>
            <div>@(Model.BirthDay?.ToString("dd/MM/yyyy") ?? "—")</div>
        </div>
        <div class="info-row">
            <div class="info-label">Date Joined</div>
            <div>@Model.CreatedAt.ToString("MMMM dd, yyyy - HH:mm")</div>
        </div>
    </div>
</div>