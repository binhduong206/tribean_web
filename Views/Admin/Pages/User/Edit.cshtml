@model Tribean.Models.User
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit User";
    ViewData["PageTitle"] = "Edit User";
    ViewData["Breadcrumb"] = "Catalog / Users / Edit";
    var roles = ViewData["Roles"] as IEnumerable<Tribean.Models.Role>;
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/users.css" />
    <link rel="stylesheet" href="~/Admin/css/image-upload.css" />
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Edit User</h1>
        <p>Updating profile for <strong>@Model.UserName</strong></p>
    </div>
    <div class="page-header-actions">
        <a href="/Admin/User" class="btn btn-secondary btn-sm" style="display: inline-flex; align-items: center; gap: 6px;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Users
        </a>
    </div>
</div>

@* Thông báo lỗi chung từ Server *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-error mb-16">@TempData["Error"]</div>
}

<form id="editUserForm" method="post" action="/Admin/User/Update/@Model.Id" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    
    <div class="user-form-grid">
        <div class="card user-form-main">
            <div class="card-header">
                <span class="card-title">Account Information</span>
            </div>
            <div class="card-body">
                <div class="d-flex gap-16">
                    <div class="form-group flex-1">
                        <label class="form-label">First Name</label>
                        <input type="text" id="FirstName" name="FirstName" value="@Model.FirstName" class="form-control" placeholder="e.g. Nguyễn" />
                    </div>
                    <div class="form-group flex-1">
                        <label class="form-label">Last Name</label>
                        <input type="text" id="LastName" name="LastName" value="@Model.LastName" class="form-control" placeholder="TriBean" />
                    </div>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Username *</label>
                    <input type="text" id="UserName" name="UserName" value="@Model.UserName" class="form-control" />
                    @Html.ValidationMessage("UserName", "", new { @class = "user-text-danger text-danger error-msg" })
                </div>
                
                <div class="form-group">
                    <label class="form-label">Password <span class="text-muted" style="font-size: 12px; font-weight: normal;">(Leave blank to keep current)</span></label>
                    <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="Enter new password if you want to change" />
                    @Html.ValidationMessage("newPassword", "", new { @class = "user-text-danger text-danger error-msg" })
                </div>
                
                <div class="d-flex gap-16">
                    <div class="form-group flex-1">
                        <label class="form-label">Email *</label>
                        <input type="email" id="Email" name="Email" value="@Model.Email" class="form-control" />
                        @Html.ValidationMessage("Email", "", new { @class = "user-text-danger text-danger error-msg" })
                    </div>
                    <div class="form-group flex-1">
                        <label class="form-label">Phone *</label>
                        <input type="text" id="PhoneNumber" name="PhoneNumber" value="@Model.PhoneNumber" class="form-control" />
                        @Html.ValidationMessage("PhoneNumber", "", new { @class = "user-text-danger text-danger error-msg" })
                    </div>
                </div>
            </div>
        </div>

        <div class="user-form-side">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Profile Image</span>
                </div>
                <div class="card-body">
                    <div class="img-upload-zone" id="uploadZone" onclick="document.getElementById('mainImage').click()">
                        <img id="imgPreview" src="@Model.AvatarUrl" alt="" style="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "display:none;" : "display:block;") width:160px; height:160px; object-fit:cover; border-radius:50%; margin: 0 auto;" />
                        <div id="uploadPlaceholder" style="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "display:block;" : "display:none;")">
                            <div class="img-upload-icon">
                                <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4"/></svg>
                            </div>
                            <div class="img-upload-text">Click to change image</div>
                            <div class="img-upload-hint">PNG, JPG up to 5MB</div>
                        </div>
                        <input type="file" id="mainImage" name="mainImage" style="display:none;" accept="image/*" onchange="previewImage(this)" />
                    </div>
                </div>
            </div>
            
            <div class="card">
                <div class="card-header"><span class="card-title">Access Role</span></div>
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label">Select Role</label>
                        <select id="RoleId" name="RoleId" class="form-control">
                            <option value="">-- Choose --</option>
                            @if(roles != null) 
                            {
                                foreach(var r in roles) 
                                { 
                                    <option value="@r.Id" selected="@(Model.RoleId == r.Id ? "selected" : null)">@r.RoleName</option> 
                                }
                            }
                        </select>
                        @Html.ValidationMessage("RoleId", "", new { @class = "user-text-danger text-danger error-msg" })
                    </div>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center">
                Update User
            </button>
            <a href="/Admin/User" class="btn btn-secondary" style="width:100%;justify-content:center;">
                Cancel
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/Admin/js/index.js"></script>
    <script src="~/Validates/user-validation.js"></script>
}