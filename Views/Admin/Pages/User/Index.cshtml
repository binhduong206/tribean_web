@* Views/Admin/Pages/User/Index.cshtml *@
@model IEnumerable<Tribean.Models.User>
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "Users";
    ViewData["PageTitle"] = "Users";
    ViewData["Breadcrumb"] = "Catalog / Users";
    
    var totalUsers = ViewData["TotalUsers"] as int? ?? 0;
    var totalAdmins = ViewData["TotalAdmins"] as int? ?? 0;
    var totalClients = ViewData["TotalClients"] as int? ?? 0;

    var currentSearch = ViewData["Search"] as string ?? "";
    var currentRole = ViewData["RoleFilter"] as string ?? "";
    var currentPage = (int)(ViewData["Page"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/users.css" />
    <link rel="stylesheet" href="~/Admin/css/filter-bar.css" />
    <link rel="stylesheet" href="~/Admin/css/table-actions.css" />
}

@* ── Thông báo ── *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error">@TempData["Error"]</div>
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Users</h1>
        <p>Manage customers and administrator accounts.</p>
    </div>
    <div class="page-header-actions">
        <a href="/Admin/User/Create" class="btn btn-primary btn-sm">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add User
        </a>
    </div>
</div>

@* ── Khối Thống kê ── *@
<div class="user-stats-strip">
    <div class="user-stat-item">
        <div class="user-stat-icon total">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </div>
        <div>
            <div class="user-stat-val">@totalUsers.ToString("N0")</div>
            <div class="user-stat-label">Total Users</div>
        </div>
    </div>

    <div class="user-stat-item">
        <div class="user-stat-icon admin">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
        </div>
        <div>
            <div class="user-stat-val">@totalAdmins.ToString("N0")</div>
            <div class="user-stat-label">Admins</div>
        </div>
    </div>

    <div class="user-stat-item">
        <div class="user-stat-icon client">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
        </div>
        <div>
            <div class="user-stat-val">@totalClients.ToString("N0")</div>
            <div class="user-stat-label">Clients</div>
        </div>
    </div>
</div>

@* ── Thanh Filter ── *@
<form method="get" action="/Admin/User" id="filterForm">
    <div class="filter-bar">
        <div class="filter-search">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
            <input type="text" name="search" value="@currentSearch" placeholder="Search by name, email, phone..." autocomplete="off" />
        </div>
        <select class="form-control" name="role" onchange="this.form.submit()">
            <option value="">All Roles</option>
            <option value="Admin" selected="@(currentRole == "Admin" ? "selected" : null)">Admin</option>
            <option value="Client" selected="@(currentRole == "Client" ? "selected" : null)">Client</option>
        </select>
        
        @if (!string.IsNullOrEmpty(currentSearch) || !string.IsNullOrEmpty(currentRole))
        {
            <a href="/Admin/User" class="btn btn-secondary btn-sm btn-clear">✕ Clear</a>
        }
    </div>
</form>

<div class="card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">👥</div>
            <p>No users found matching your criteria.</p>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th style="width:40px;"><input type="checkbox" id="checkAll" /></th>
                        <th>User</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th style="width:100px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var fullName = string.IsNullOrWhiteSpace(u.FirstName) && string.IsNullOrWhiteSpace(u.LastName) 
                                        ? "—" : $"{u.FirstName} {u.LastName}".Trim();
                        var initial = !string.IsNullOrEmpty(u.UserName) ? u.UserName.Substring(0, 1).ToUpper() : "U";
                        var roleName = u.Role?.RoleName ?? "Client";
                        var phone = string.IsNullOrEmpty(u.PhoneNumber) ? "—" : u.PhoneNumber;
                        var email = string.IsNullOrEmpty(u.Email) ? "—" : u.Email;
                        
                        var badgeClass = roleName.ToLower().Contains("admin") ? "badge-purple" : "badge-green";

                        <tr>
                            <td><input type="checkbox" class="row-check" value="@u.Id" /></td>
                            
                            @* ── 1. Cột User (Gộp Avatar + Tên y hệt Product) ── *@
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    @if (!string.IsNullOrEmpty(u.AvatarUrl))
                                    {
                                        <img src="@u.AvatarUrl" alt="@u.UserName" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--sb-accent-soft); color: var(--sb-accent); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: bold;">@initial</div>
                                    }
                                    <div>
                                        <div style="font-weight: 600; color: var(--text-primary); font-size: 14px;">@u.UserName</div>
                                        <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">@fullName</div>
                                    </div>
                                </div>
                            </td>

                            @* ── 2. Các cột thông tin tách rời ── *@
                            <td style="color: var(--text-muted);">@email</td>
                            <td style="color: var(--text-secondary);">@phone</td>
                            <td>
                                <span class="badge @badgeClass">@roleName</span>
                            </td>
                            <td style="color:var(--text-muted);font-size:13px;">
                                @u.CreatedAt.ToString("dd/MM/yyyy")
                            </td>

                            @* ── 3. Cột Actions (Copy 100% từ bảng Product) ── *@
                            <td>
                                <div class="table-actions">
                                    <a class="action-btn view" href="/Admin/User/Detail/@u.Id" title="View">
                                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S3.732 16.057 2.458 12z" />
                                        </svg>
                                    </a>
                                    <a class="action-btn edit" href="/Admin/User/Edit/@u.Id" title="Edit">
                                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                    <form method="post" action="/Admin/User/Delete/@u.Id" style="display:inline;" onsubmit="return confirm('Delete @u.UserName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn delete" title="Delete">
                                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="card-footer">
            <span style="font-size:13px;color:var(--text-muted);">
                Showing @Model.Count() out of @totalUsers users
            </span>
            <div class="pagination">
                <a class="page-btn @(currentPage <= 1 ? "disabled" : "")" href="?page=@(currentPage-1)&search=@currentSearch&role=@currentRole">‹</a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a class="page-btn @(i == currentPage ? "active" : "")" href="?page=@i&search=@currentSearch&role=@currentRole">@i</a>
                }
                <a class="page-btn @(currentPage >= totalPages ? "disabled" : "")" href="?page=@(currentPage+1)&search=@currentSearch&role=@currentRole">›</a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/Admin/js/index.js"></script>
}