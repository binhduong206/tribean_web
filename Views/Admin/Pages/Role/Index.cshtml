@* Views/Admin/Pages/Role/Index.cshtml *@
@model IEnumerable<Tribean.Models.Role>
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentPage = (int)(ViewData["Page"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/roles.css" />
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error">@TempData["Error"]</div>
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Roles</h1>
        <p>Manage user access roles.</p>
    </div>
    <div class="page-header-actions">
        <a href="/Admin/Role/Create" class="btn btn-primary btn-sm btn-icon">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Role
        </a>
    </div>
</div>

<form method="get" action="/Admin/Role" id="filterForm">
    <div class="filter-bar">
        <div class="filter-search">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
            <input type="text" name="search" value="@currentSearch" placeholder="Search roles..." autocomplete="off" />
        </div>
        
        @if (!string.IsNullOrEmpty(currentSearch))
        {
            <a href="/Admin/Role" class="btn btn-secondary btn-sm" style="height: 38px;">✕ Clear</a>
        }
    </div>
</form>

<div class="card role-table-section">
    <div class="card-header">
        <span class="card-title">All Roles</span>
        <span class="card-subtitle">@Model.Count() items on this page</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <p>No roles found.</p>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th class="col-id">STT</th>
                        <th class="col-name">Role Name</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int idx = (currentPage - 1) * 10 + 1; }
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td class="cell-id">@(idx++)</td>
                            <td class="cell-name">@role.RoleName</td>
                            <td>
                                <div class="table-actions">
                                    <a href="/Admin/Role/Edit/@role.Id" class="action-btn edit" title="Edit">
                                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="18" height="18">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                    <form method="post" action="/Admin/Role/Delete/@role.Id" class="form-inline" onsubmit="return confirm('Are you sure you want to delete role @role.RoleName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn delete" title="Delete">
                                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="18" height="18">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="card-header" style="border-top:1px solid var(--card-border); border-bottom:none;">
            <span class="card-subtitle">Page @currentPage of @totalPages</span>
            <div class="pagination">
                <a class="page-btn @(currentPage <= 1 ? "disabled" : "")" href="?page=@(currentPage-1)&search=@currentSearch">‹</a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a class="page-btn @(i == currentPage ? "active" : "")" href="?page=@i&search=@currentSearch">@i</a>
                }
                <a class="page-btn @(currentPage >= totalPages ? "disabled" : "")" href="?page=@(currentPage+1)&search=@currentSearch">›</a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/Admin/js/index.js"></script>
}