@* Views/Admin/Pages/Role/Add.cshtml *@
@model Tribean.Models.Role
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/roles.css" />
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Add Role</h1>
        <p>Create a new access level for your team and customers.</p>
    </div>
    <div class="page-header-actions">
        <a href="/Admin/Role" class="btn btn-secondary btn-sm" style="display: inline-flex; align-items: center; gap: 6px;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Roles
        </a>
    </div>
</div>

<div class="card role-form-container">
    <div class="card-header">
        <span class="card-title">Role Information</span>
    </div>
    <div class="card-body">
        <form method="post" action="/Admin/Role/Create">
            @Html.AntiForgeryToken()
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-error">
                    @Html.ValidationSummary(true, "")
                </div>
            }

            <div class="form-group">
                <label class="form-label">Role Name <span class="text-danger">*</span></label>
                <input type="text" 
                       name="RoleName" 
                       class="form-control" 
                       placeholder="e.g. Admin, Editor, Customer" 
                       required 
                       value="@Model?.RoleName" />
                @Html.ValidationMessageFor(m => m.RoleName, "", new { @class = "text-danger" })
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create Role</button>
                <a href="/Admin/Role" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>