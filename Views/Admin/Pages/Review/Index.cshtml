@model IEnumerable<Tribean.Models.Review>
@using Tribean.Routers.Admin
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "Customer Reviews";
    ViewData["PageTitle"] = "Reviews";
    ViewData["Breadcrumb"] = "Sales / Reviews";
    var totalItems = (int)(ViewData["TotalItems"] ?? 0);
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/reviews.css" />
    <link rel="stylesheet" href="~/Admin/css/table-actions.css" />
}

@if (TempData["Success"] != null) { <div class="alert alert-success mb-16">@TempData["Success"]</div> }
@if (TempData["Error"] != null)   { <div class="alert alert-error mb-16">@TempData["Error"]</div> }

<div class="page-header">
    <div class="page-header-info">
        <h1>Customer Reviews</h1>
        <p>Monitor and moderate user feedback on your products.</p>
    </div>
    <div class="page-header-actions">
        <a href="/@ReviewRouter.Seed" class="btn btn-secondary btn-sm" title="Generate Fake Data for Testing">
            🧪 Generate Fake Reviews
        </a>
    </div>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">⭐</div>
            <p>No reviews yet. Customers haven't rated any products.</p>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Rating & Comment</th>
                        <th>Date</th>
                        <th style="width:80px; text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>
                                <div class="rev-user-cell">
                                    <div class="rev-avatar">
                                        @if (r.User != null && !string.IsNullOrEmpty(r.User.AvatarUrl))
                                        {
                                            <img src="@r.User.AvatarUrl" alt="Avatar" />
                                        }
                                        else
                                        {
                                            @(r.User?.UserName.Substring(0,1).ToUpper() ?? "?")
                                        }
                                    </div>
                                    <div class="rev-user-info">
                                        <span class="rev-user-name">@(r.User?.UserName ?? "Unknown User")</span>
                                        <span class="rev-user-id">#@r.UserId.Substring(0,6).ToUpper()</span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="badge badge-yellow">@(r.Product?.ProductName ?? "Deleted Product")</span>
                            </td>

                            <td>
                                <div class="rev-rating-wrap">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= r.Rating) { <span class="rev-star-filled">★</span> }
                                        else               { <span class="rev-star-empty">★</span> }
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(r.Comment))
                                {
                                    <div class="rev-comment">"@r.Comment"</div>
                                    @if (r.Comment.Length > 60)
                                    {
                                        <a href="javascript:void(0)" class="read-more-btn" 
                                           onclick="openReviewModal('@Html.Raw(r.User?.UserName?.Replace("'", "\\'"))', '@Html.Raw(r.Product?.ProductName?.Replace("'", "\\'"))', @r.Rating, '@Html.Raw(r.Comment.Replace("'", "\\'").Replace("\n", "\\n"))')"
                                           style="font-size: 12px; color: var(--sb-accent); font-weight: 500; text-decoration: none; margin-top: 4px; display: inline-block;">
                                            Read full review &rarr;
                                        </a>
                                    }
                                }
                                else
                                {
                                    <div class="rev-comment" style="color: #ccc;">(No comment)</div>
                                }
                            </td>

                            <td class="rev-date">
                                @r.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>

                            <td>
                                <div class="table-actions" style="justify-content: flex-end;">
                                    <form method="post" action="/@ReviewRouter.Delete.Replace("{id}", r.Id)" onsubmit="return confirm('Delete this review permanently?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn delete" title="Delete Spam">
                                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ── Phân Trang ── *@
        <div class="card-footer">
            <span style="font-size:13px; color:var(--text-muted);">
                Showing @Model.Count() out of @totalItems reviews
            </span>
            <div class="pagination">
                @{
                    var page = (int)(ViewData["Page"] ?? 1);
                    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
                }
                <a class="page-btn @(page <= 1 ? "disabled" : "")" href="?page=@(page - 1)">‹</a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a class="page-btn @(i == page ? "active" : "")" href="?page=@i">@i</a>
                }
                <a class="page-btn @(page >= totalPages ? "disabled" : "")" href="?page=@(page + 1)">›</a>
            </div>
        </div>
    }
</div>

<div id="reviewDetailModal" class="rev-modal-overlay">
    <div class="rev-modal-box">
        <div class="rev-modal-header">
            <h3>Review Details</h3>
            <button class="rev-close-btn" onclick="closeReviewModal()">✖</button>
        </div>
        <div class="rev-modal-body">
            <div class="rev-modal-meta">
                <div><strong>Customer:</strong> <span id="mdlCustomer"></span></div>
                <div style="margin-top: 8px;"><strong>Product:</strong> <span class="badge badge-yellow" id="mdlProduct"></span></div>
                <div style="margin-top: 8px;"><strong>Rating:</strong> <span id="mdlRating" class="rev-rating-wrap"></span></div>
            </div>
            <div class="rev-modal-text" id="mdlComment"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/js/index.js"></script>
}