@* Views/Admin/Pages/Product/Index.cshtml *@
@model IEnumerable<Tribean.Models.Product>
@using Tribean.Helpers
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "Products";
    ViewData["PageTitle"] = "Products";
    ViewData["Breadcrumb"] = "Catalog / Products";

    var categories = ViewData["Categories"] as IEnumerable<Tribean.Models.Category> ?? Enumerable.Empty<Tribean.Models.Category>();
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentCategory = ViewData["CategoryFilter"] as string ?? "";
    var currentStatus = ViewData["StatusFilter"] as string ?? "";
    
    // Lấy danh sách FULL để dùng riêng cho Dạng Lưới
    var allProducts = ViewData["AllProducts"] as IEnumerable<Tribean.Models.Product> ?? Enumerable.Empty<Tribean.Models.Product>();
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/products.css" />
    <link rel="stylesheet" href="~/Admin/css/filter-bar.css" />
    <link rel="stylesheet" href="~/Admin/css/table-actions.css" />
}

@* ── TempData alerts (Dùng class CSS Base, không inline) ── *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error">@TempData["Error"]</div>
}

@* ── Page Header ── *@
<div class="page-header">
    <div class="page-header-info">
        <h1>Products</h1>
        <p>Manage your coffee menu and items.</p>
    </div>
    <div class="page-header-actions">
        <a href="/Admin/Product/Create" class="btn btn-primary btn-sm">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Product
        </a>
    </div>
</div>

@* ── Filter Bar ── *@
<form method="get" action="/Admin/Product" id="filterForm">
    <div class="filter-bar">
        <div class="filter-search">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
            <input type="text" name="search" value="@currentSearch" placeholder="Search products…" autocomplete="off" />
        </div>

        <select class="form-control" name="category" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var cat in categories)
            {
                <option value="@cat.Id" selected="@(currentCategory == cat.Id ? "selected" : null)">
                    @cat.CategoryName
                </option>
            }
        </select>

        <select class="form-control" name="status" onchange="this.form.submit()">
            <option value="">All Status</option>
            <option value="true" selected="@(currentStatus == "true" ? "selected" : null)">Active</option>
            <option value="false" selected="@(currentStatus == "false" ? "selected" : null)">Inactive</option>
        </select>

        @if (!string.IsNullOrEmpty(currentSearch) || !string.IsNullOrEmpty(currentCategory) || !string.IsNullOrEmpty(currentStatus))
        {
            <a href="/Admin/Product" class="btn btn-secondary btn-sm">✕ Clear</a>
        }

        <div class="filter-spacer"></div>

        <div class="view-toggle">
            <button type="button" class="view-btn active" id="tableViewBtn" onclick="setView('table')" title="Table view">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 6h18M3 14h18M3 18h18" />
                </svg>
            </button>
            <button type="button" class="view-btn" id="gridViewBtn" onclick="setView('grid')" title="Grid view">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                </svg>
            </button>
        </div>
    </div>
</form>

<div class="card">
    @if (!allProducts.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📦</div>
            <p>No products found. <a href="/Admin/Product/Create" class="text-accent">Add your first product</a>.</p>
        </div>
    }
    else
    {
        @* ── Table View ── *@
        <div id="tableView">
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th style="width:40px;"><input type="checkbox" id="checkAll" /></th>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Discount</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th style="width:100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Lặp qua Model (Danh sách bị giới hạn 5 sản phẩm) *@
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td><input type="checkbox" class="row-check" value="@p.Id" /></td>
                                <td>
                                    <div class="product-img-cell">
                                        @if (!string.IsNullOrEmpty(p.MainImgUrl))
                                        {
                                            <img src="@p.MainImgUrl" alt="@p.ProductName" class="product-thumb-table" />
                                        }
                                        else
                                        {
                                            <div class="product-thumb-table" style="display:flex;align-items:center;justify-content:center;font-size:20px;">☕</div>
                                        }
                                        <div>
                                            <div class="product-name-table">@p.ProductName</div>
                                            <div class="product-id-table">#@p.Id[..8].ToUpper()</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-yellow">@(p.Category?.CategoryName ?? "—")</span>
                                </td>
                                <td>
                                    @if (p.Discount > 0)
                                    {
                                        <span class="product-discount-table active">-@p.Discount%</span>
                                    }
                                    else
                                    {
                                        <span class="product-discount-table none">0%</span>
                                    }
                                </td>
                                <td>
                                    @if (p.Discount > 0)
                                    {
                                        <div style="display: flex; flex-direction: column;">
                                            <span class="product-price-table">@p.Price.ToString("N0")$</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="product-price-table">@p.Price.ToString("N0")$</span>
                                    }
                                </td>
                                <td>
                                    @if (p.Status)
                                    {
                                        <span class="badge badge-green toggle-status-btn" 
                                              onclick="toggleStatus('@p.Id', this)">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-red toggle-status-btn" 
                                              onclick="toggleStatus('@p.Id', this)">Inactive</span>
                                    }
                                </td>
                                <td style="color:var(--text-muted);font-size:13px;">
                                    @p.CreatedAt.ToString("dd/MM/yyyy")
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a class="action-btn view" href="/Admin/Product/Detail/@p.Id" title="View">
                                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S3.732 16.057 2.458 12z" />
                                            </svg>
                                        </a>
                                        <a class="action-btn edit" href="/Admin/Product/Edit/@p.Id" title="Edit">
                                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                            </svg>
                                        </a>
                                        <form method="post" action="/Admin/Product/Delete/@p.Id" style="display:inline;" onsubmit="return confirm('Delete @p.ProductName?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="action-btn delete" title="Delete">
                                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ── Phân Trang (CÓ ID #paginationControls ĐỂ JS NHẬN DIỆN VÀ ẨN) ── *@
        <div id="paginationControls" class="card-header" style="border-top:1px solid var(--card-border);border-bottom:none; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px;">
            <span style="font-size:13px;color:var(--text-muted);">
                Showing @Model.Count() out of @allProducts.Count() products
            </span>
            <div class="pagination">
                @{
                    var page = (int)(ViewData["Page"] ?? 1);
                    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
                }
                <a class="page-btn @(page <= 1 ? "disabled" : "")"
                   href="?page=@(page - 1)&search=@currentSearch&category=@currentCategory&status=@currentStatus">‹</a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a class="page-btn @(i == page ? "active" : "")"
                       href="?page=@i&search=@currentSearch&category=@currentCategory&status=@currentStatus">@i</a>
                }
                <a class="page-btn @(page >= totalPages ? "disabled" : "")"
                   href="?page=@(page + 1)&search=@currentSearch&category=@currentCategory&status=@currentStatus">›</a>
            </div>
        </div>

        @* ── Grid View ── *@
        <div id="gridView" style="display:none; padding: 20px;">
            <div class="products-grid">
                @* Lặp qua allProducts (Danh sách lấy toàn bộ) *@
                @foreach (var p in allProducts)
                {
                    <div class="product-grid-card">
                        <div class="product-grid-img" style="position: relative;">
                            @if (!string.IsNullOrEmpty(p.MainImgUrl))
                            {
                                <img src="@p.MainImgUrl" alt="@p.ProductName" />
                            }
                            else
                            {
                                <span style="font-size:52px; display: flex; justify-content: center; align-items: center; height: 100%;">☕</span>
                            }
                            
                            @if (p.Discount > 0)
                            {
                                <div style="position: absolute; top: 10px; right: 10px; background-color: #d93025; color: white; font-size: 12px; font-weight: bold; padding: 4px 8px; border-radius: 4px; z-index: 2;">
                                    -@p.Discount%
                                </div>
                            }

                            <div class="product-grid-overlay">
                                <a class="overlay-btn" href="/Admin/Product/Detail/@p.Id" title="View">
                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="16" height="16">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S3.732 16.057 2.458 12z" />
                                    </svg>
                                </a>
                                <a class="overlay-btn" href="/Admin/Product/Edit/@p.Id" title="Edit">
                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="16" height="16">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                        <div class="product-grid-body">
                            <div class="product-grid-cat">@(p.Category?.CategoryName ?? "—")</div>
                            <div class="product-grid-name">@p.ProductName</div>
                            <div class="product-grid-footer">
                                @if (p.Discount > 0)
                                {
                                    var finalPrice = PriceHelper.CalculateFinalPrice(p.Price, p.Discount);
                                    <div style="display: flex; flex-direction: column;">
                                        <span style="color: #d93025; font-weight: bold; font-size: 16px;">@finalPrice.ToString("N0")$</span>
                                        <span style="color: var(--text-muted); text-decoration: line-through; font-size: 13px;">@p.Price.ToString("N0")$</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="product-grid-price">@p.Price.ToString("N0")$</span>
                                }

                                @if (p.Status)
                                {
                                    <span class="badge badge-green toggle-status-btn" 
                                        onclick="toggleStatus('@p.Id', this)">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-red toggle-status-btn" 
                                        onclick="toggleStatus('@p.Id', this)">Inactive</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/Admin/js/alert.js"></script>
}