@* Views/Admin/Pages/Product/Detail.cshtml *@
@model Tribean.Models.Product
@using Tribean.Helpers
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "Product Detail";
    ViewData["PageTitle"] = "Product Detail";
    ViewData["Breadcrumb"] = "Catalog / Products / Detail";
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/products.css" />
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Product Detail</h1>
        <p>Viewing details for <strong>@Model.ProductName</strong></p>
    </div>
    <div class="page-header-actions header-actions-group">
        <a href="/Admin/Product" class="btn btn-secondary btn-sm btn-icon-wrapper">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Products
        </a>
        <a href="/Admin/Product/Edit/@Model.Id" class="btn btn-primary btn-sm btn-icon-wrapper">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit Product
        </a>
    </div>
</div>

<div class="detail-grid">
    @* ── Cột Trái: Hình Ảnh ── *@
    <div class="detail-image-box">
        @if (!string.IsNullOrEmpty(Model.MainImgUrl))
        {
            <img src="@Model.MainImgUrl" alt="@Model.ProductName" />
        }
        else
        {
            <div class="empty-image-box">
                <span class="empty-image-icon">☕</span>
            </div>
            <p class="empty-image-text">No image uploaded</p>
        }
    </div>

    @* ── Cột Phải: Thông tin chi tiết ── *@
    <div class="detail-info-box">
        <h2 class="detail-title">@Model.ProductName</h2>
        
        <div class="detail-meta">
            <span class="badge badge-yellow detail-badge">@(Model.Category?.CategoryName ?? "No Category")</span>
            @if (Model.Status)
            {
                <span class="badge badge-green detail-badge">Active</span>
            }
            else
            {
                <span class="badge badge-red detail-badge">Inactive</span>
            }
        </div>

        <div class="detail-price-box">
            <div>
                <span class="price-label">Selling Price</span>
                @{
                    var finalPrice = PriceHelper.CalculateFinalPrice(Model.Price, Model.Discount);
                }
                <span class="price-final">@finalPrice.ToString("N0")$</span>
            </div>
            
            @if (Model.Discount > 0)
            {
                <div class="text-right">
                    <span class="price-label">Original Price</span>
                    <span class="price-original">@Model.Price.ToString("N0")$</span>
                    <span class="badge price-discount-badge">-@Model.Discount%</span>
                </div>
            }
            else
            {
                <div class="text-right">
                    <span class="price-label">Discount</span>
                    <span class="price-original" style="text-decoration: none;">0%</span>
                </div>
            }
        </div>

        <h4 class="detail-section-title">Product Details</h4>
        <div class="info-row">
            <div class="info-label">Date Created</div>
            <div>@Model.CreatedAt.ToString("MMMM dd, yyyy - HH:mm")</div>
        </div>
        <div class="info-row">
            <div class="info-label">Description</div>
            <div class="detail-description">@(string.IsNullOrEmpty(Model.Description) ? "No description provided for this product." : Model.Description)</div>
        </div>
    </div>
</div>