@* Views/Admin/Pages/Dashboard.cshtml *@
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard";
    ViewData["Breadcrumb"] = "Overview";
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/dashboard.css" />
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Good morning, Admin 👋</h1>
        <p>Here's what's happening with TriBean today.</p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Export
        </button>
        <button class="btn btn-primary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            New Order
        </button>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card accent-gold">
        <div class="stat-header">
            <div class="stat-icon gold">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <span class="stat-change up">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                </svg>
                +12.5%
            </span>
        </div>
        <div class="stat-value">₫24,560,000</div>
        <div class="stat-label">Total Revenue</div>
    </div>

    <div class="stat-card accent-green">
        <div class="stat-header">
            <div class="stat-icon green">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <span class="stat-change up">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                </svg>
                +8.2%
            </span>
        </div>
        <div class="stat-value">148</div>
        <div class="stat-label">Total Orders</div>
    </div>

    <div class="stat-card accent-blue">
        <div class="stat-header">
            <div class="stat-icon blue">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
            </div>
            <span class="stat-change up">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                </svg>
                +4.1%
            </span>
        </div>
        <div class="stat-value">2,340</div>
        <div class="stat-label">Total Users</div>
    </div>

    <div class="stat-card accent-purple">
        <div class="stat-header">
            <div class="stat-icon purple">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
            </div>
            <span class="stat-change down">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
                -2.3%
            </span>
        </div>
        <div class="stat-value">36</div>
        <div class="stat-label">Total Products</div>
    </div>
</div>


<div class="charts-row">
    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-card-title">Revenue Overview</div>
                <div class="chart-card-subtitle">Monthly revenue comparison</div>
            </div>
            <div class="chart-period-tabs">
                <span class="period-tab active">7D</span>
                <span class="period-tab">1M</span>
                <span class="period-tab">6M</span>
                <span class="period-tab">1Y</span>
            </div>
        </div>
        <div class="chart-placeholder">
            <div class="chart-bar-group"><div class="chart-bar primary" style="height:60%"></div><div class="chart-bar secondary" style="height:40%"></div></div>
            <div class="chart-bar-group"><div class="chart-bar primary" style="height:75%"></div><div class="chart-bar secondary" style="height:55%"></div></div>
            <div class="chart-bar-group"><div class="chart-bar primary" style="height:50%"></div><div class="chart-bar secondary" style="height:35%"></div></div>
            <div class="chart-bar-group"><div class="chart-bar primary" style="height:90%"></div><div class="chart-bar secondary" style="height:65%"></div></div>
            <div class="chart-bar-group"><div class="chart-bar primary" style="height:70%"></div><div class="chart-bar secondary" style="height:50%"></div></div>
            <div class="chart-bar-group"><div class="chart-bar primary" style="height:85%"></div><div class="chart-bar secondary" style="height:60%"></div></div>
            <div class="chart-bar-group"><div class="chart-bar primary" style="height:100%"></div><div class="chart-bar secondary" style="height:72%"></div></div>
        </div>
        <div class="chart-x-labels">
            <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-card-title">Order Status</div>
                <div class="chart-card-subtitle">Current breakdown</div>
            </div>
        </div>
        <div class="donut-wrap">
            <svg width="150" height="150" viewBox="0 0 150 150">
                <circle cx="75" cy="75" r="55" fill="none" stroke="#f3f4f6" stroke-width="20"/>
                <circle cx="75" cy="75" r="55" fill="none" stroke="#10b981" stroke-width="20"
                        stroke-dasharray="138 207" stroke-dashoffset="0" stroke-linecap="round"/>
                <circle cx="75" cy="75" r="55" fill="none" stroke="#3b82f6" stroke-width="20"
                        stroke-dasharray="83 262" stroke-dashoffset="-138" stroke-linecap="round"/>
                <circle cx="75" cy="75" r="55" fill="none" stroke="#f59e0b" stroke-width="20"
                        stroke-dasharray="55 290" stroke-dashoffset="-221" stroke-linecap="round"/>
                <circle cx="75" cy="75" r="55" fill="none" stroke="#ef4444" stroke-width="20"
                        stroke-dasharray="28 317" stroke-dashoffset="-276" stroke-linecap="round"/>
            </svg>
            <div class="donut-center">
                <div class="donut-center-val">148</div>
                <div class="donut-center-label">Total</div>
            </div>
        </div>
        <div class="donut-legend">
            <div class="legend-item">
                <div class="legend-dot" style="background:#10b981"></div>
                <span class="legend-label">Delivered</span>
                <span class="legend-val">66</span>
            </div>
            <div class="legend-item">
                <div class="legend-dot" style="background:#3b82f6"></div>
                <span class="legend-label">Shipping</span>
                <span class="legend-val">40</span>
            </div>
            <div class="legend-item">
                <div class="legend-dot" style="background:#f59e0b"></div>
                <span class="legend-label">Pending</span>
                <span class="legend-val">28</span>
            </div>
            <div class="legend-item">
                <div class="legend-dot" style="background:#ef4444"></div>
                <span class="legend-label">Cancelled</span>
                <span class="legend-val">14</span>
            </div>
        </div>
    </div>
</div>

<div class="bottom-row">
    <div class="card">
        <div class="card-header">
            <span class="card-title">Recent Orders</span>
            <a href="/Admin/Order" class="btn btn-secondary btn-sm">View all</a>
        </div>
        <div class="card-body" style="padding: 0 20px;">
            <div class="recent-order-row">
                <span class="order-id-cell">#ORD-001</span>
                <span class="order-customer">Nguyễn Văn A</span>
                <span class="badge badge-yellow">Pending</span>
                <span class="order-amount">₫155,000</span>
            </div>
            <div class="recent-order-row">
                <span class="order-id-cell">#ORD-002</span>
                <span class="order-customer">Trần Thị B</span>
                <span class="badge badge-blue">Shipping</span>
                <span class="order-amount">₫220,000</span>
            </div>
            <div class="recent-order-row">
                <span class="order-id-cell">#ORD-003</span>
                <span class="order-customer">Lê Minh C</span>
                <span class="badge badge-green">Delivered</span>
                <span class="order-amount">₫310,000</span>
            </div>
            <div class="recent-order-row">
                <span class="order-id-cell">#ORD-004</span>
                <span class="order-customer">Phạm Thu D</span>
                <span class="badge badge-red">Cancelled</span>
                <span class="order-amount">₫98,000</span>
            </div>
            <div class="recent-order-row">
                <span class="order-id-cell">#ORD-005</span>
                <span class="order-customer">Hoàng Đức E</span>
                <span class="badge badge-green">Delivered</span>
                <span class="order-amount">₫175,000</span>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title">Top Products</span>
            <a href="/Admin/Product" class="btn btn-secondary btn-sm">View all</a>
        </div>
        <div class="card-body" style="padding: 0 20px;">
            <div class="top-product-row">
                <span class="product-rank">1</span>
                <div class="product-thumb" style="background:#fef3c7;border-radius:6px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">☕</div>
                <div class="product-info">
                    <div class="product-info-name">Cà Phê Sữa</div>
                    <div class="product-info-cat">Espresso</div>
                </div>
                <span class="product-sales">320</span>
            </div>
            <div class="top-product-row">
                <span class="product-rank">2</span>
                <div class="product-thumb" style="background:#dbeafe;border-radius:6px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">🧊</div>
                <div class="product-info">
                    <div class="product-info-name">Cold Brew</div>
                    <div class="product-info-cat">Cold Drinks</div>
                </div>
                <span class="product-sales">285</span>
            </div>
            <div class="top-product-row">
                <span class="product-rank">3</span>
                <div class="product-thumb" style="background:#d1fae5;border-radius:6px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">🍵</div>
                <div class="product-info">
                    <div class="product-info-name">Matcha Latte</div>
                    <div class="product-info-cat">Tea</div>
                </div>
                <span class="product-sales">241</span>
            </div>
            <div class="top-product-row">
                <span class="product-rank">4</span>
                <div class="product-thumb" style="background:#ede9fe;border-radius:6px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">🧋</div>
                <div class="product-info">
                    <div class="product-info-name">Trà Sữa Taro</div>
                    <div class="product-info-cat">Milk Tea</div>
                </div>
                <span class="product-sales">198</span>
            </div>
            <div class="top-product-row">
                <span class="product-rank">5</span>
                <div class="product-thumb" style="background:#ffedd5;border-radius:6px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">🍫</div>
                <div class="product-info">
                    <div class="product-info-name">Chocolate Đá</div>
                    <div class="product-info-cat">Chocolate</div>
                </div>
                <span class="product-sales">176</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Period tab toggle
    document.querySelectorAll('.period-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            tab.closest('.chart-period-tabs').querySelectorAll('.period-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
        });
    });
</script>
}
