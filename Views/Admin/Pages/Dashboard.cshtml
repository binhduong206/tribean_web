@using Tribean.Controllers.Admin
@using Tribean.Models.Enums
@using Tribean.Models.ViewModels
@model DashboardViewModel
@{
    Layout = "~/Views/Admin/Layouts/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard";
    ViewData["Breadcrumb"] = "Overview";
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/dashboard.css" />
}

<div class="page-header">
    <div class="page-header-info">
        <h1>Good morning, Admin</h1>
        <p>Here's what's happening with TriBean today.</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card accent-gold">
        <div class="stat-header">
            <div class="stat-icon gold">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <span class="stat-change @(Model.RevenueGrowth >= 0 ? "up" : "down")">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="@(Model.RevenueGrowth >= 0 ? "M5 10l7-7m0 0l7 7m-7-7v18" : "M19 14l-7 7m0 0l-7-7m7 7V3")" /></svg>
                @(Model.RevenueGrowth >= 0 ? "+" : "")@Model.RevenueGrowth%
            </span>
        </div>
        <div class="stat-value">$@Model.TotalRevenue.ToString("N0")</div>
        <div class="stat-label">Total Revenue (Delivered)</div>
    </div>

    <div class="stat-card accent-green">
        <div class="stat-header">
            <div class="stat-icon green">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
            </div>
            <span class="stat-change @(Model.OrdersGrowth >= 0 ? "up" : "down")">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="@(Model.OrdersGrowth >= 0 ? "M5 10l7-7m0 0l7 7m-7-7v18" : "M19 14l-7 7m0 0l-7-7m7 7V3")" /></svg>
                @(Model.OrdersGrowth >= 0 ? "+" : "")@Model.OrdersGrowth%
            </span>
        </div>
        <div class="stat-value">@Model.TotalOrders.ToString("N0")</div>
        <div class="stat-label">Total Orders</div>
    </div>

    <div class="stat-card accent-blue">
        <div class="stat-header">
            <div class="stat-icon blue">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <span class="stat-change @(Model.UsersGrowth >= 0 ? "up" : "down")">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="@(Model.UsersGrowth >= 0 ? "M5 10l7-7m0 0l7 7m-7-7v18" : "M19 14l-7 7m0 0l-7-7m7 7V3")" /></svg>
                @(Model.UsersGrowth >= 0 ? "+" : "")@Model.UsersGrowth%
            </span>
        </div>
        <div class="stat-value">@Model.TotalUsers.ToString("N0")</div>
        <div class="stat-label">Total Users</div>
    </div>

    <div class="stat-card accent-purple">
        <div class="stat-header">
            <div class="stat-icon purple">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
            </div>
            <span class="stat-change @(Model.ProductsGrowth >= 0 ? "up" : "down")">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="@(Model.ProductsGrowth >= 0 ? "M5 10l7-7m0 0l7 7m-7-7v18" : "M19 14l-7 7m0 0l-7-7m7 7V3")" /></svg>
                @(Model.ProductsGrowth >= 0 ? "+" : "")@Model.ProductsGrowth%
            </span>
        </div>
        <div class="stat-value">@Model.TotalProducts.ToString("N0")</div>
        <div class="stat-label">Total Products</div>
    </div>
</div>

<div class="charts-row">
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">Revenue Overview</div>
            <div class="chart-card-subtitle">Last 7 Days vs Previous Week</div>
        </div>
        <div class="chart-canvas-wrap">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">Order Status</div>
            <div class="chart-card-subtitle">All-time breakdown</div>
        </div>
        <div class="donut-chart-container">
            <div class="donut-canvas-wrap">
                <canvas id="orderStatusChart"></canvas>
            </div>
            <div class="donut-legend">
                <div class="legend-item">
                    <div class="legend-dot dot-delivered"></div>
                    <span class="legend-label">Delivered</span>
                    <span class="legend-val">@Model.DeliveredCount</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot dot-shipping"></div>
                    <span class="legend-label">Shipping</span>
                    <span class="legend-val">@Model.ShippingCount</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot dot-confirmed"></div>
                    <span class="legend-label">Confirmed</span>
                    <span class="legend-val">@Model.ConfirmedCount</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot dot-pending"></div>
                    <span class="legend-label">Pending</span>
                    <span class="legend-val">@Model.PendingCount</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot dot-cancelled"></div>
                    <span class="legend-label">Cancelled</span>
                    <span class="legend-val">@Model.CancelledCount</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bottom-row">
    <div class="card">
        <div class="card-header">
            <span>Recent Orders</span>
            <a href="/Admin/Order" class="btn btn-secondary btn-sm">View all</a>
        </div>
        <div>
            <div class="list-header-row grid-recent-orders">
                <span class="header-text">Order ID</span>
                <span class="header-text">Customer</span>
                <span class="header-text">Date</span>
                <span class="header-text text-center">Status</span>
                <span class="header-text text-right">Amount</span>
            </div>
            @if(!Model.RecentOrders.Any()) { <div class="empty-state-msg">No orders yet.</div> }
            @foreach (var o in Model.RecentOrders)
            {
                var badgeClass = o.Status switch { 
                    OrderStatus.Pending => "badge-yellow", OrderStatus.Confirmed => "badge-purple",
                    OrderStatus.Shipping => "badge-blue", OrderStatus.Delivered => "badge-green", 
                    OrderStatus.Cancelled => "badge-red", _ => "badge-secondary" 
                };
                <div class="recent-order-row grid-recent-orders">
                    <span class="order-id-cell">#@o.Id.Substring(0, 8).ToUpper()</span>
                    <div class="customer-cell">
                        <div class="customer-avatar">
                            @if(o.User != null && !string.IsNullOrEmpty(o.User.AvatarUrl)) { <img src="@o.User.AvatarUrl" alt="Avatar" /> }
                            else { @(string.IsNullOrEmpty(o.User?.UserName) ? "?" : o.User.UserName.Substring(0, 1).ToUpper()) }
                        </div>
                        <span class="customer-name">@(o.User?.UserName ?? "Unknown User")</span>
                    </div>
                    <span class="order-date-cell">@o.OrderDate.ToString("MMM dd, yyyy")</span>
                    <span class="text-center"><span class="badge @badgeClass">@o.Status</span></span>
                    <span class="order-amount text-right">$@o.TotalPrice.ToString("N0")</span>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span>Top Products</span>
            <a href="/Admin/Product" class="btn btn-secondary btn-sm">View all</a>
        </div>
        <div>
            <div class="list-header-row grid-top-products">
                <span class="header-text text-center">#</span>
                <span class="thumb-spacer"></span>
                <span class="header-text">Product</span>
                <span class="header-text text-right">Sales</span>
            </div>
            @if(!Model.TopProducts.Any()) { <div class="empty-state-msg">Not enough data.</div> }
            @{ int rank = 1; }
            @foreach (var tp in Model.TopProducts)
            {
                var emojis = new[] { "☕", "🧊", "🍵", "🧋", "🍫" };
                var bgClass = $"rank-bg-{((rank - 1) % 5) + 1}";
                <div class="top-product-row grid-top-products">
                    <span class="product-rank text-center">@rank</span>
                    <div class="product-thumb @bgClass">
                        @if(!string.IsNullOrEmpty(tp.Product?.MainImgUrl)) { <img src="@tp.Product.MainImgUrl" class="thumb-img" /> }
                        else { @emojis[(rank - 1) % emojis.Length] }
                    </div>
                    <div class="product-info">
                        <div class="product-info-name">@(tp.Product?.ProductName ?? "Deleted")</div>
                        <div class="product-info-cat">@(tp.Product?.Category?.CategoryName ?? "—")</div>
                    </div>
                    <span class="product-sales text-right">@tp.TotalSold sold</span>
                </div>
                rank++;
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span>Recent Registrations</span>
            <a href="/Admin/User" class="btn btn-secondary btn-sm">View all</a>
        </div>
        <div>
            <div class="list-header-row grid-recent-users">
                <span class="header-text">Customer</span>
                <span class="header-text">Email</span>
                <span class="header-text text-right">Joined Date</span>
            </div>
            @if(!Model.RecentUsers.Any()) { <div class="empty-state-msg">No users yet.</div> }
            @foreach (var u in Model.RecentUsers)
            {
                <div class="recent-order-row grid-recent-users">
                    <div class="customer-cell">
                        <div class="customer-avatar">
                            @if(!string.IsNullOrEmpty(u.AvatarUrl)) { <img src="@u.AvatarUrl" alt="Avatar" /> }
                            else { @(string.IsNullOrEmpty(u.UserName) ? "?" : u.UserName.Substring(0, 1).ToUpper()) }
                        </div>
                        <span class="customer-name">@(u.UserName ?? "Unknown User")</span>
                    </div>
                    <span class="user-email-cell">@u.Email</span>
                    <span class="user-date-cell">@u.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span>Top Spenders</span>
            <a href="/Admin/User" class="btn btn-secondary btn-sm">View all</a>
        </div>
        <div>
            <div class="list-header-row grid-top-spenders">
                <span class="header-text text-center">#</span>
                <span class="header-text">Customer</span>
                <span class="header-text text-center">Orders</span>
                <span class="header-text text-right">Spent</span>
            </div>
            @if(!Model.TopSpenders.Any()) { <div class="empty-state-msg">Not enough data.</div> }
            @{ int spenderRank = 1; }
            @foreach (var ts in Model.TopSpenders)
            {
                <div class="top-product-row grid-top-spenders">
                    <span class="product-rank text-center">@spenderRank</span>
                    <div class="customer-cell">
                        <div class="customer-avatar">
                            @if(ts.User != null && !string.IsNullOrEmpty(ts.User.AvatarUrl)) { <img src="@ts.User.AvatarUrl" alt="Avatar" /> }
                            else { @(string.IsNullOrEmpty(ts.User?.UserName) ? "?" : ts.User.UserName.Substring(0, 1).ToUpper()) }
                        </div>
                        <span class="customer-name">@(ts.User?.UserName ?? "Unknown User")</span>
                    </div>
                    <span class="text-center" style="font-size: 13px; font-weight: 600; color: var(--text-secondary);">@ts.TotalOrders</span>
                    <span class="order-amount text-right">$@ts.TotalSpent.ToString("N0")</span>
                </div>
                spenderRank++;
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. BAR CHART: REVENUE OVERVIEW
        const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
        const revLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueLast7Days.Select(x => x.DayName)));
        const curRevData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueLast7Days.Select(x => x.CurrentRevenue)));
        const prevRevData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueLast7Days.Select(x => x.PreviousRevenue)));

        new Chart(ctxRevenue, {
            type: 'bar',
            data: {
                labels: revLabels,
                datasets: [
                    { label: 'This Week ($)', data: curRevData, backgroundColor: '#d93025', borderRadius: 4, barPercentage: 0.6 },
                    { label: 'Last Week ($)', data: prevRevData, backgroundColor: '#fef3c7', borderRadius: 4, barPercentage: 0.6 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top', align: 'end' } },
                scales: {
                    y: { 
                        beginAtZero: true, 
                        grid: { borderDash: [4, 4] }, 
                        ticks: { callback: v => v >= 1000000 ? (v/1000000)+'M' : v >= 1000 ? (v/1000)+'K' : v } 
                    },
                    x: { grid: { display: false } }
                }
            }
        });

        // 2. DONUT CHART: ORDER STATUS
        new Chart(document.getElementById('orderStatusChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Delivered', 'Shipping', 'Confirmed', 'Pending', 'Cancelled'],
                datasets: [{
                    data: [
                        @Model.DeliveredCount, 
                        @Model.ShippingCount, 
                        @Model.ConfirmedCount, 
                        @Model.PendingCount, 
                        @Model.CancelledCount
                    ],
                    backgroundColor: ['#10b981', '#3b82f6', '#8b5cf6', '#f59e0b', '#ef4444'], 
                    borderWidth: 0
                }]
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: false, 
                cutout: '75%', 
                plugins: { legend: { display: false } } 
            }
        });
    </script>
}