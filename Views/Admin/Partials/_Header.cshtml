@using System.Security.Claims
@using Tribean.Routers.Admin
@{
    // Móc thông tin từ Cookie ra
    var userName = User.Identity?.Name ?? "Admin";
    var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? userName;
    var initial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "A";
    var role = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "Administrator";
    var avatarUrl = User.Claims.FirstOrDefault(c => c.Type == "AvatarUrl")?.Value;
}

<header class="admin-header">
    <div class="header-left">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <div class="page-title-wrap">
            <div class="page-title">@(ViewData["PageTitle"] ?? ViewData["Title"] ?? "Dashboard")</div>
            @if (ViewData["Breadcrumb"] != null)
            {
                <div class="page-breadcrumb">
                    <span>Admin</span>
                    <span class="breadcrumb-sep">/</span>
                    <span>@ViewData["Breadcrumb"]</span>
                </div>
            }
        </div>
    </div>

    <div class="header-right">
        <div class="profile-dropdown-wrap" style="position: relative;">
            
            <div class="user-avatar" id="profileDropdownBtn" style="width:34px;height:34px;font-size:13px;border:2px solid var(--card-border);color:var(--text-secondary);background:var(--content-bg);cursor:pointer; display:flex; align-items:center; justify-content:center; border-radius:50%; font-weight: 600; overflow:hidden;">
                @if (!string.IsNullOrEmpty(avatarUrl))
                {
                    <img src="@avatarUrl" alt="Avatar" style="width:100%;height:100%;object-fit:cover;" />
                }
                else
                {
                    @initial
                }
            </div>

            <div class="profile-dropdown-menu" id="profileDropdownMenu">
                <div class="profile-header-info" style="display:flex; align-items:center; gap:12px;">
                    <div style="width:42px;height:42px;border-radius:50%;overflow:hidden;background:var(--content-bg);color:var(--sb-accent);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:bold;flex-shrink:0;">
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="Avatar" style="width:100%;height:100%;object-fit:cover;" />
                        }
                        else
                        {
                            @initial
                        }
                    </div>
                    <div>
                        <div class="profile-name">@fullName</div>
                        <div class="profile-role">@role</div>
                    </div>
                </div>
                
                <div class="profile-divider"></div>
                
                <a href="/Admin/User/Edit/@User.FindFirst(ClaimTypes.NameIdentifier)?.Value" class="profile-menu-item">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    My Profile
                </a>

                <a href="javascript:void(0)" id="themeToggleBtn" class="profile-menu-item">
                    <span style="display:flex; align-items:center; justify-content:center; width:16px; height:16px;">
                        <svg id="moonIcon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display: block; width: 100%; height: 100%;"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
                        <svg id="sunIcon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display: none; width: 100%; height: 100%;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                    </span>
                    <span id="themeText">Dark Mode</span>
                </a>
                
                <div class="profile-divider"></div>
                
                <a href="/@AuthRouter.Logout" class="profile-menu-item text-danger">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                    Logout
                </a>
            </div>
        </div>
    </div>
</header>