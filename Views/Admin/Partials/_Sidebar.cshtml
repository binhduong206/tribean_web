@* Views/Admin/Partials/_Sidebar.cshtml *@
@using Tribean.Data
@using Tribean.Models.Enums
@using System.Security.Claims

@* Tiêm thẳng Database vào Partial View này *@
@inject ApplicationDbContext _db

@{
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path) => currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);

    // Đếm tự động số lượng đơn hàng Pending
    var pendingOrderCount = _db.Orders.Count(o => o.Status == OrderStatus.Pending);

    // Móc thông tin User từ Cookie (Giống bên Header)
    var userName = User.Identity?.Name ?? "Admin";
    var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? userName;
    var initial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "A";
    var role = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "Administrator";
    var avatarUrl = User.Claims.FirstOrDefault(c => c.Type == "AvatarUrl")?.Value;
}

<aside class="sidebar" id="sidebar">

    <div class="sidebar-logo">
        <img src="~/Images/logo.png" alt="TriBean Logo" class="logo-icon" />
        <div>
            <div class="logo-text">Tri<span>Bean</span></div>
            <div class="logo-sub">Admin Panel</div>
        </div>
    </div>

    <nav class="sidebar-nav">

        <div class="nav-group">
            <span class="nav-group-label">Main</span>

            <a class="nav-item @(IsActive("/Admin/Dashboard") ? "active" : "")"
               href="/Admin/Dashboard">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Dashboard
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">Catalog</span>

            <a class="nav-item @(IsActive("/Admin/Product") ? "active" : "")"
               href="/Admin/Product">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
                Products
            </a>

            <a class="nav-item @(IsActive("/Admin/Category") ? "active" : "")"
               href="/Admin/Category">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
                </svg>
                Categories
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">Sales</span>

            <a class="nav-item @(IsActive("/Admin/Order") ? "active" : "")" href="/Admin/Order">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                Orders
                
                @* Đặt ID và logic ẩn hiện bằng CSS *@
                <span id="pendingOrderBadge" class="nav-badge" style="display: @(pendingOrderCount > 0 ? "inline-flex" : "none")">
                    @pendingOrderCount
                </span>
            </a>

            <a class="nav-item @(IsActive("/Admin/Discount") ? "active" : "")"
               href="/Admin/Discount">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M7 7h.01M17 17h.01M7 17h.01M17 7h.01M3 3l18 18" />
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" fill="none"/>
                </svg>
                Discounts
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">People</span>

            <a class="nav-item @(IsActive("/Admin/User") ? "active" : "")"
               href="/Admin/User">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Users
            </a>

            <a class="nav-item @(IsActive("/Admin/Role") ? "active" : "")"
               href="/Admin/Role">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" 
                          d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4v-5.257A7.011 7.011 0 0115 7z" />
                </svg>
                Roles
            </a>

            <a class="nav-item @(IsActive("/Admin/Review") ? "active" : "")"
               href="/Admin/Review">
                <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                Reviews
            </a>
        </div>

    </nav>

    <div class="sidebar-footer">
        <a href="/Admin/User/Edit/@User.FindFirst(ClaimTypes.NameIdentifier)?.Value" class="sidebar-user" style="text-decoration: none; display: flex;">
            <div class="user-avatar" style="overflow: hidden; display: flex; align-items: center; justify-content: center; background: var(--card-bg); color: var(--sb-accent);">
                @if (!string.IsNullOrEmpty(avatarUrl))
                {
                    <img src="@avatarUrl" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;" />
                }
                else
                {
                    @initial
                }
            </div>
            <div class="user-info">
                <div class="user-name">@fullName</div>
                <div class="user-role">@role</div>
            </div>
            <svg class="user-menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
            </svg>
        </a>
    </div>

</aside>